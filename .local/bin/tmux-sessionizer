#!/bin/bash
source $HOME/.config/sessionizer
sessionizer "$@"
sessionizer_name=${sessionizer_name/./_}

if [[ -z $TMUX ]]; then
    tmux new-session -As $sessionizer_name -c $sessionizer_dir \
        -e SESSIONIZER_DIR=$sessionizer_dir
    exit
fi

if ! tmux has-session -t $sessionizer_name 2> /dev/null; then
    tmux new-session -ds $sessionizer_name -c $sessionizer_dir \
        -e SESSIONIZER_DIR=$sessionizer_dir
fi

tmux switch-client -t $sessionizer_name

